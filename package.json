{
  "name": "runsheet",
  "version": "0.7.0",
  "description": "Type-safe, composable business logic pipelines for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "llms.txt"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "./scripts/lint.sh",
    "lint:fix": "./scripts/lint.sh --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "!({CLAUDE,CHANGELOG}).md": [
      "markdownlint-cli2 --fix"
    ],
    "llms.txt": [
      "prettier --write",
      "markdownlint-cli2 --fix"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "pipeline",
    "workflow",
    "orchestration",
    "service-object",
    "rollback",
    "typescript",
    "composable"
  ],
  "author": "Scott Haug",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaug/runsheet-js.git"
  },
  "bugs": {
    "url": "https://github.com/shaug/runsheet-js/issues"
  },
  "homepage": "https://github.com/shaug/runsheet-js#readme",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0",
    "zod": "^3.22.0"
  }
}
